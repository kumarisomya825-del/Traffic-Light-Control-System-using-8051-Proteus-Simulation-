ORG 0000H

START:
    SETB P1.0
    CLR  P1.1
    CLR  P1.2

    ACALL DELAY
    ACALL DELAY

    CLR  P1.0
    SETB P1.1
    CLR  P1.2

    ACALL DELAY
    ACALL DELAY

    CLR  P1.0
    CLR  P1.1
    SETB P1.2

    ACALL DELAY
    ACALL DELAY

    SJMP START

; -------- DELAY FUNCTION --------
DELAY:
    MOV R4, #0FFH
D1: MOV R5, #0FFH
D2: DJNZ R5, D2
    DJNZ R4, D1
    RET
END

END
